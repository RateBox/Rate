# Website URL
WEBSITE_URL=http://localhost:3001
PORT=3001

# Internal URL for API calls within Docker network
NEXT_INTERNAL_API_URL=http://strapi:1337

# Public URL for browser access
NEXT_PUBLIC_API_URL=http://localhost:1337
NEXT_PUBLIC_API_PROTOCOL=http

# Public URL for media files
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337

# Preview mode
PREVIEW_SECRET=your-secret-key

# Debug
NODE_ENV=development
# DEBUG=next:*
NEXT_TELEMETRY_DISABLED=1

# Image Optimizer settings - use internal Docker network
NEXT_IMAGE_OPTIMIZER_URL=http://strapi:1337

# Image Optimizer settings - use localhost for browser access
NEXT_PUBLIC_IMAGE_HOSTNAME=localhost
NEXT_PUBLIC_IMAGE_PORT=1337