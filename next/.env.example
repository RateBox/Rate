# Website URL
WEBSITE_URL=http://localhost:3001 # URL website Next.js khi chạy locally
PORT=3001

# Internal URL for API calls within Docker network
NEXT_INTERNAL_API_URL=http://strapi:1337 # URL nội bộ để gọi API trong mạng Docker

# Public URL for media files
NEXT_PUBLIC_API_URL=http://localhost:1337 # URL công khai để truy cập Strapi từ bên ngoài
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337 # URL công khai cho Strapi
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337 # URL công khai cho media files từ Strapi

# Preview mode
PREVIEW_SECRET=your-preview-secret-here # Secret key cho chế độ preview

# Debug settings
NODE_ENV=development # Môi trường phát triển
# DEBUG=next:* # Uncomment để bật debug logs
NEXT_TELEMETRY_DISABLED=1 # Tắt telemetry của Next.js

# Image Optimizer settings
NEXT_PUBLIC_IMAGE_HOSTNAME=strapi # Hostname của Strapi cho Next Image Optimizer
NEXT_PUBLIC_IMAGE_PORT=1337 # Port của Strapi cho Next Image Optimizer

# Optional: Analytics, etc.
# NEXT_PUBLIC_GA_ID=your-ga-id # Google Analytics ID
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn # Sentry DSN