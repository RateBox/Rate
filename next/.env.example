# Website URL
WEBSITE_URL=http://localhost:3001 # Add the correct ENV var for this onto your hosting platform, point it to your production website.
PORT=3001

# Internal URL for API calls within Docker network
NEXT_INTERNAL_API_URL=http://strapi:1337

# Public URL for media files
NEXT_PUBLIC_API_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337

# Preview mode
PREVIEW_SECRET=your-preview-secret-here

# Debug settings
NODE_ENV=development
DEBUG=next:*
NEXT_TELEMETRY_DISABLED=1

# Optional: Analytics, etc.
# NEXT_PUBLIC_GA_ID=your-ga-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn